{
  "expo": {
    "name": "Care-Giver Sync",
    "slug": "care-giver-sync",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0F1E",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0F1E"
      },
      "package": "com.caregiiversync.app"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.caregiiversync.app"
    },
    "assetBundlePatterns": ["**/*"]
  }
}
